---
import '../styles/global.css';
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/logo-decoda.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>deCoda</title>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <img src="/logo-decoda.png" alt="deCoda" />
        <h1>de<span>Coda</span></h1>
      </div>

      <p class="description">
        Homelab pessoal rodando aplicações self-hosted em um NAS UGREEN.
      </p>

      <div class="status-list">
        <div class="status">
          <span class="status-dot online"></span>
          <span class="status-text">Coda Finances — online</span>
        </div>

        <div class="status">
          <span class="status-dot online"></span>
          <span class="status-text">Immich — online</span>
        </div>

        <div class="status">
          <span class="status-dot online"></span>
          <span class="status-text">Paperless-ngx — online</span>
        </div>
      </div>

      <p class="section-label">Hardware</p>
      <div class="hardware">
        <p class="hardware-item">
          <strong>Dispositivo</strong> — UGREEN DXP2800<br />
          <strong>RAM</strong> — 8 GB<br />
          <strong>Armazenamento</strong> — 4 TB HDD (RAID 1) + 500 GB SSD<br />
          <strong>Sistema</strong> — UGOS Pro
        </p>
      </div>

    </div>


  </body>
</html>
